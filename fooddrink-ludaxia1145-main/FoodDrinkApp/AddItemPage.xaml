<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record">
    <!-- Main scrollable container -->
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF5F0, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFFBF8, Dark=#0F1711}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <!-- Header section -->
            <Border StrokeThickness="0" Padding="18" BackgroundColor="{AppThemeBinding Light=#FFFFFE, Dark=#1A1712}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Label Text="Add food or drink"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Record the full details of a meal worth remembering."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#8B6D55, Dark=#D8C4AC}" />
                </Grid>
            </Border>

            <!-- Basic information section -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light#FFFFFE, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Basic information" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#E55031, Dark=#FF9C7B}" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Name"
                           FontSize="14"
                           PlaceholderColor="#A88A72"
                           SemanticProperties.Hint="Required food or drink name" />
                    <Picker x:Name="CategoryPicker"
                            Title="Category"
                            FontSize="14"
                            SemanticProperties.Hint="Required category">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavour, or context"
                            AutoSize="TextChanges"
                            HeightRequest="110"
                            FontSize="14"
                            PlaceholderColor="#A88A72"
                            SemanticProperties.Hint="Describe this food or drink" />
                </VerticalStackLayout>
            </Border>

            <!-- Nutrition section -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light#FFFFFE, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nutrition data" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#35845A, Dark=#8CE6A1}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CaloriesEntry"
                               Placeholder="Calories"
                               Keyboard="Numeric"
                               FontSize="14"
                               PlaceholderColor="#A88A72"
                               SemanticProperties.Hint="Required calories as a number" />
                        <Entry x:Name="ProteinEntry"
                               Grid.Column="1"
                               Placeholder="Protein g"
                               Keyboard="Numeric"
                               FontSize="14"
                               PlaceholderColor="#A88A72" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CarbsEntry"
                               Placeholder="Carbs g"
                               Keyboard="Numeric"
                               FontSize="14"
                               PlaceholderColor="#A88A72" />
                        <Entry x:Name="FatEntry"
                               Grid.Column="1"
                               Placeholder="Fat g"
                               Keyboard="Numeric"
                               FontSize="14"
                               PlaceholderColor="#A88A72" />
                    </Grid>
                    <Entry x:Name="AllergyEntry"
                           Placeholder="Allergy note or dietary restriction"
                           FontSize="14"
                           PlaceholderColor="#A88A72"
                           SemanticProperties.Hint="Enter allergy or dietary information" />
                </VerticalStackLayout>
            </Border>

            <!-- Validation error panel -->
            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#FFE8E0, Dark=#40201C}"
                    Padding="14">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#C74428, Dark=#FFB4A6}"
                       FontAttributes="Bold"
                       FontSize="13" />
            </Border>

            <!-- Save button -->
            <Button Text="Save record"
                    FontAttributes="Bold"
                    FontSize="15"
                    BackgroundColor="#E55031"
                    TextColor="#FFFFFF"
                    Padding="0,14"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Validate and save this record" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
