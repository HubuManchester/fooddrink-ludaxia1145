<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <!-- Main scrollable container for nutrition details -->
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF5F0, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFFBF8, Dark=#0F1711}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="22" Spacing="16">
            <!-- Nutrition header banner -->
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#E55031, Dark=#5B2017}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#F2A238, Dark=#9B4A19}" Offset="0.72" />
                        <GradientStop Color="{AppThemeBinding Light=#35845A, Dark=#1D5D3A}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <!-- Food item name -->
                    <Label x:Name="NameLabel"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <!-- Category badge -->
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="14"
                           TextColor="#FFF8F0" />
                    <!-- Calorie display -->
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="26"
                           FontAttributes="Bold"
                           TextColor="#FFFFC9" />
                </Grid>
            </Border>

            <!-- Nutrition details card -->
            <Border StrokeThickness="1"
                    Stroke="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFE, Dark=#1A1712}"
                    Padding="16">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="12">
                    <Label Text="Nutrition overview" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#E55031, Dark=#FF9C7B}" />
                    <!-- Macronutrients summary -->
                    <Label x:Name="MacroLabel" FontSize="14" TextColor="{AppThemeBinding Light=#35845A, Dark=#8CE6A1}" FontAttributes="Bold" />
                    <BoxView HeightRequest="1" Color="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}" />
                    <!-- Description and allergy info -->
                    <Label x:Name="DescriptionLabel" FontSize="14" TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}" />
                    <Label x:Name="AllergyLabel" FontSize="13" FontAttributes="Bold" TextColor="{AppThemeBinding Light#B85517, Dark=#FFD18E}" />
                </VerticalStackLayout>
            </Border>

            <!-- Action buttons for accessibility features -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                <Button Text="Read summary"
                        FontSize="14"
                        FontAttributes="Bold"
                        BackgroundColor="#E55031"
                        TextColor="#FFFFFF"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        FontSize="14"
                        FontAttributes="Bold"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFE, Dark=#1A1712}"
                        BorderColor="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}"
                        BorderWidth="2"
                        TextColor="{AppThemeBinding Light=#E55031, Dark=#FFB15D}"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

            <!-- Vibration feedback button -->
            <Button Text="Vibration reminder"
                    FontSize="14"
                    FontAttributes="Bold"
                    BackgroundColor="#35845A"
                    TextColor="#FFFFFF"
                    Padding="0,14"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
