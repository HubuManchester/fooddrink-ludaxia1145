<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="NutriBite">
    <!-- Main layout with two sections: hero header and food list -->
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#FFF5F0, Dark=#130F0C}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#FFFBF8, Dark=#0F1711}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#FAFAF8, Dark=#0E1511}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Hero header banner with app branding and search controls -->
        <Grid Padding="20,18,20,18">
            <Border StrokeThickness="0" Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="12" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#E55031, Dark=#5B2017}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#F2A238, Dark=#9B4A19}" Offset="0.62" />
                        <GradientStop Color="{AppThemeBinding Light=#35845A, Dark=#1D5D3A}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#40000000" Offset="0,6" Radius="16" Opacity="0.5" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="10">
                    <!-- App title and subtitle -->
                    <Label Text="NutriBite"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Track nutrition, flavour, photos, and meal context in one place."
                           FontSize="14"
                           TextColor="#FFF8F0"
                           LineBreakMode="WordWrap" />
                    <!-- Feature badges highlighting key capabilities -->
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,3,0,0">
                        <Border BackgroundColor="#28FFFFFF" StrokeThickness="0" Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="Nutrition" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#28FFFFFF" StrokeThickness="0" Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="Photos" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#28FFFFFF" StrokeThickness="0" Padding="12,8">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="Voice" TextColor="#FFFFFF" FontSize="12" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                        </Border>
                    </Grid>
                    <!-- Search and add controls -->
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                        <Border StrokeThickness="2"
                                Stroke="#FFCB9D"
                                BackgroundColor="#FFFFFE"
                                Padding="2">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#3A2518"
                                       PlaceholderColor="#A88A72"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="#35845A"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                FontSize="15"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Scrollable food items list with refresh capability -->
        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,16,16,20">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <!-- Food item card with colored accent bar -->
                        <Border StrokeThickness="1"
                                Stroke="{AppThemeBinding Light=#EDCBB8, Dark=#3E3023}"
                                BackgroundColor="{AppThemeBinding Light=#FFFFFE, Dark=#1A1712}"
                                Padding="0"
                                Margin="0,0,0,12">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="10" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#18000000" Offset="0,4" Radius="12" Opacity="0.25" />
                            </Border.Shadow>
                            <!-- Left accent bar and content grid -->
                            <Grid ColumnDefinitions="6,*">
                                <BoxView BackgroundColor="{AppThemeBinding Light=#E55031, Dark=#FF8C6A}" />
                                <Grid Grid.Column="1" Padding="16" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                                    <!-- Food name and calories badge -->
                                    <Label Text="{Binding Name}"
                                           FontSize="18"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#3A2518, Dark=#FFF2DF}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#FFF0C9, Dark=#4A3417}"
                                            Padding="12,6">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#B85517, Dark=#FFE5B4}" />
                                    </Border>
                                    <!-- Description and macros -->
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           TextColor="{AppThemeBinding Light=#6E5A47, Dark=#D8C4AC}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="12"
                                           TextColor="{AppThemeBinding Light=#35845A, Dark=#8CE6A1}"
                                           FontAttributes="Bold" />
                                    <!-- Category and details button -->
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,4,0,0">
                                        <Label Text="{Binding Category}"
                                               FontSize="12"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#E55031, Dark=#FF9C7B}" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="14,6"
                                                FontSize="12"
                                                BackgroundColor="{AppThemeBinding Light=#E55031, Dark=#FFB15D}"
                                                TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#261307}"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
