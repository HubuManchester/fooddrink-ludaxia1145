<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.HardwarePage"
             Title="Hardware Demo">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0D1B24}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F9FB, Dark=#0F1E2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>

        <VerticalStackLayout Padding="24" Spacing="18">
            <Border StrokeThickness="0" Padding="22" BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label Text="Mobile hardware"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A3A52, Dark=#E8F4F8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Text="Demonstrate camera, location, speech, vibration, and haptic feedback."
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#5A7A92, Dark=#B8D8E8}" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Food photo" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0D7DBE, Dark=#7DD4E6}" />
                            <Label Text="Capture the colour and condition of the meal." FontSize="14" TextColor="{AppThemeBinding Light=#5A7A92, Dark=#B8D8E8}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Photo"
                                FontSize="16"
                                Padding="16,12"
                                BackgroundColor="#0D7DBE"
                                TextColor="#FFFFFF"
                                CornerRadius="22"
                                Clicked="OnTakePhotoClicked"
                                SemanticProperties.Hint="Open the camera to capture a food image" />
                    </Grid>
                    <Border StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#D9EBF4, Dark=#1E3A50}"
                            HeightRequest="220">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Image x:Name="FoodPhoto"
                               Aspect="AspectFill"
                               SemanticProperties.Description="Captured food photo preview" />
                    </Border>
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Meal location" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#06A8B8, Dark=#6EC9D8}" />
                            <Label Text="Show country, city, region, and coordinates." FontSize="14" TextColor="{AppThemeBinding Light=#5A7A92, Dark=#B8D8E8}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Locate"
                                FontSize="16"
                                Padding="16,12"
                                BackgroundColor="#06A8B8"
                                TextColor="#FFFFFF"
                                CornerRadius="22"
                                Clicked="OnGetLocationClicked"
                                SemanticProperties.Hint="Use location to record the meal place" />
                    </Grid>
                    <Label x:Name="LocationLabel"
                           Grid.Row="1"
                           Text="Location has not been captured yet."
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#4A6A7A, Dark=#C0D8E8}" />
                    <Label x:Name="CoordinateLabel"
                           Grid.Row="2"
                           Text="Coordinates will appear here."
                           FontSize="14"
                           TextColor="{AppThemeBinding Light#7A9CB8, Dark=#98B8D8}" />
                </Grid>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Button Text="Read help"
                        FontSize="16"
                        Padding="0,14"
                        BackgroundColor="#1FA5D9"
                        TextColor="#FFFFFF"
                        CornerRadius="22"
                        Clicked="OnReadHelpClicked"
                        SemanticProperties.Hint="Read the help text aloud" />
                <Button Grid.Column="1"
                        Text="Stop speech"
                        FontSize="16"
                        Padding="0,14"
                        BackgroundColor="{AppThemeBinding Light#FFFBF9, Dark=#1A2227}"
                        BorderColor="{AppThemeBinding Light#B8E0F0, Dark=#3E4A5A}"
                        BorderWidth="2"
                        TextColor="{AppThemeBinding Light#0D7DBE, Dark=#7DD4E6}"
                        CornerRadius="22"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop current speech" />
            </Grid>

            <Button Text="Haptic feedback"
                    FontSize="17"
                    Padding="0,15"
                    BackgroundColor="{AppThemeBinding Light#FFFBF9, Dark=#1A2227}"
                    BorderColor="{AppThemeBinding Light#B8E0F0, Dark#3E4A5A}"
                    BorderWidth="2"
                    TextColor="{AppThemeBinding Light#06A8B8, Dark#6EC9D8}"
                    CornerRadius="24"
                    Clicked="OnFeedbackClicked"
                    SemanticProperties.Hint="Trigger vibration and haptic feedback" />

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light#FFFBF9, Dark#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="12">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="14">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Motion sensors" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light#0D7DBE, Dark#7DD4E6}" />
                            <Label Text="Detect motion and orientation changes." FontSize="14" TextColor="{AppThemeBinding Light#5A7A92, Dark#B8D8E8}" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1"
                                Text="Measure"
                                FontSize="16"
                                Padding="16,12"
                                BackgroundColor="#0D7DBE"
                                TextColor="#FFFFFF"
                                CornerRadius="22"
                                Clicked="OnMeasureMotionClicked"
                                SemanticProperties.Hint="Measure accelerometer and gyroscope" />
                    </Grid>
                    <Label x:Name="AccelerometerLabel"
                           Grid.Row="1"
                           Text="Accelerometer: Ready"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light#4A6A7A, Dark#C0D8E8}" />
                    <Label x:Name="GyroscopeLabel"
                           Grid.Row="2"
                           Text="Gyroscope: Ready"
                           FontSize="15"
                           TextColor="{AppThemeBinding Light#4A6A7A, Dark#C0D8E8}" />
                    <Label x:Name="MotionStatusLabel"
                           Grid.Row="3"
                           Text="Move your device to capture sensor data."
                           FontSize="13"
                           TextColor="{AppThemeBinding Light#7A9CB8, Dark#98B8D8}" />
                </Grid>
            </Border>

            <Border StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light#D9EBF4, Dark=#1E3A50}"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="8">
                    <Label x:Name="HardwareStatusLabel"
                           Text="Ready."
                           FontAttributes="Bold"
                           FontSize="17"
                           TextColor="{AppThemeBinding Light#0D7DBE, Dark:#7DD4E6}" />
                    <Label x:Name="FeedbackCountLabel"
                           Text="Haptic feedback tests: 0"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light#4A6A7A, Dark:#C0D8E8}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
