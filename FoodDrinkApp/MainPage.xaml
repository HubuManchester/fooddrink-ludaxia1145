<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:FoodDrinkApp.Models"
             x:Class="FoodDrinkApp.MainPage"
             Title="MealMate">
    <Grid RowDefinitions="Auto,*">
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark#0D1B24}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F9FB, Dark=#0F1E2A}" Offset="0.45" />
                <GradientStop Color="{AppThemeBinding Light=#E3F2F7, Dark=#0D1820}" Offset="1.0" />
            </LinearGradientBrush>
        </Grid.Background>

        <Grid Padding="20,18,20,18">
            <Border StrokeThickness="0" Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#0D7DBE, Dark=#1B4A6B}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#1FA5D9, Dark=#2E7AA8}" Offset="0.62" />
                        <GradientStop Color="{AppThemeBinding Light=#06A8B8, Dark=#2B6B82}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Border.Shadow>
                    <Shadow Brush="#33000000" Offset="0,8" Radius="18" Opacity="0.45" />
                </Border.Shadow>
                <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="14">
                    <Label Text="MealMate"
                           FontSize="38"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Your smart food diary - capture flavours, nutrients, and memories."
                           FontSize="16"
                           TextColor="#FFF5E8" />
                    <Grid Grid.Row="2" ColumnDefinitions="*,*,*" ColumnSpacing="12" Margin="0,6,0,0">
                        <Button BackgroundColor="#40FFFFFF" TextColor="#FFFFFF" FontSize="14" FontAttributes="Bold" CornerRadius="20" Padding="12,10" Text="Nutrition" />
                        <Button Grid.Column="1" BackgroundColor="#40FFFFFF" TextColor="#FFFFFF" FontSize="14" FontAttributes="Bold" CornerRadius="20" Padding="12,10" Text="Photos" />
                        <Button Grid.Column="2" BackgroundColor="#40FFFFFF" TextColor="#FFFFFF" FontSize="14" FontAttributes="Bold" CornerRadius="20" Padding="12,10" Text="Voice" />
                    </Grid>
                    <Grid Grid.Row="3" ColumnDefinitions="*,Auto" ColumnSpacing="12" Margin="0,8,0,0">
                        <Border StrokeThickness="2"
                                Stroke="#A0D8F0"
                                BackgroundColor="#FFFBF9"
                                Padding="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <SearchBar x:Name="SearchFoodBar"
                                       Placeholder="Search foods, drinks, categories, or tags"
                                       TextChanged="OnSearchTextChanged"
                                       SearchButtonPressed="OnSearchButtonPressed"
                                       TextColor="#2B5A7A"
                                       PlaceholderColor="#7A9CB8"
                                       BackgroundColor="Transparent"
                                       SemanticProperties.Hint="Search the food and drink list" />
                        </Border>
                        <Button Grid.Column="1"
                                Text="Add"
                                BackgroundColor="#06A8B8"
                                TextColor="#FFFFFF"
                                FontAttributes="Bold"
                                FontSize="16"
                                CornerRadius="24"
                                Padding="16,12"
                                Clicked="OnAddClicked"
                                SemanticProperties.Hint="Add a new food or drink record" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <RefreshView Grid.Row="1" x:Name="FoodRefreshView" Refreshing="OnRefreshing">
            <CollectionView x:Name="FoodCollection"
                            SelectionMode="None"
                            EmptyView="No matching food or drink records."
                            Margin="16,0,16,18">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FoodItem">
                        <Border StrokeThickness="2"
                                Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                                BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                                Padding="0"
                                Margin="0,0,0,14">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="18" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#22000000" Offset="0,5" Radius="14" Opacity="0.34" />
                            </Border.Shadow>
                            <Grid ColumnDefinitions="5,*">
                                <BoxView BackgroundColor="{AppThemeBinding Light=#0D7DBE, Dark=#4FA8D1}" />
                                <Grid Grid.Column="1" Padding="18" RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="10" ColumnSpacing="12">
                                    <Label Text="{Binding Name}"
                                           FontSize="22"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#1A3A52, Dark=#E8F4F8}"
                                           SemanticProperties.HeadingLevel="Level2" />
                                    <Border Grid.Column="1"
                                            StrokeThickness="0"
                                            BackgroundColor="{AppThemeBinding Light=#D9EBF4, Dark=#2E5A7A}"
                                            Padding="10,5">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="6" />
                                        </Border.StrokeShape>
                                        <Label Text="{Binding CaloriesLabel}"
                                               FontSize="13"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0D7DBE, Dark=#A8D9F0}" />
                                    </Border>
                                    <Label Grid.Row="1"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding Description}"
                                           FontSize="15"
                                           TextColor="{AppThemeBinding Light=#4A6A7A, Dark=#C0D8E8}"
                                           LineBreakMode="TailTruncation" />
                                    <Label Grid.Row="2"
                                           Grid.ColumnSpan="2"
                                           Text="{Binding MacroSummary}"
                                           FontSize="14"
                                           TextColor="{AppThemeBinding Light=#06A8B8, Dark=#6EC9D8}" />
                                    <Grid Grid.Row="3" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,6,0,0" ColumnSpacing="12">
                                        <Label Text="{Binding Category}"
                                               FontSize="14"
                                               FontAttributes="Bold"
                                               TextColor="{AppThemeBinding Light=#0D7DBE, Dark=#7DD4E6}" />
                                        <Button Grid.Column="1"
                                                Text="Details"
                                                Padding="18,10"
                                                FontSize="15"
                                                BackgroundColor="{AppThemeBinding Light=#0D7DBE, Dark=#1FA5D9}"
                                                TextColor="{AppThemeBinding Light=#FFFFFF, Dark=#0A1B27}"
                                                CornerRadius="22"
                                                CommandParameter="{Binding Id}"
                                                Clicked="OnDetailsClicked"
                                                SemanticProperties.Hint="Open nutrition details" />
                                    </Grid>
                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </RefreshView>
    </Grid>
</ContentPage>
