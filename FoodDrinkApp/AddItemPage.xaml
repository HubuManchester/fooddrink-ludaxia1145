<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.AddItemPage"
             Title="Add Record">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0D1B24}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F9FB, Dark=#0F1E2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Border StrokeThickness="0" Padding="22" BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>
                <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
                    <Label Text="Add food or drink"
                           FontSize="32"
                           FontAttributes="Bold"
                           TextColor="{AppThemeBinding Light=#1A3A52, Dark=#E8F4F8}"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label Grid.Row="1"
                           Text="Record the full details of a meal worth remembering."
                           FontSize="16"
                           TextColor="{AppThemeBinding Light=#5A7A92, Dark=#B8D8E8}" />
                </Grid>
            </Border>

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Label Text="Basic information" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0D7DBE, Dark=#7DD4E6}" />
                    <Entry x:Name="NameEntry"
                           Placeholder="Name"
                           SemanticProperties.Hint="Required food or drink name" />
                    <Picker x:Name="CategoryPicker"
                            Title="Category"
                            SemanticProperties.Hint="Required category">
                        <Picker.Items>
                            <x:String>Breakfast</x:String>
                            <x:String>Lunch</x:String>
                            <x:String>Dinner</x:String>
                            <x:String>Snack</x:String>
                            <x:String>Drink</x:String>
                        </Picker.Items>
                    </Picker>
                    <Editor x:Name="DescriptionEditor"
                            Placeholder="Description, ingredients, flavour, or context"
                            AutoSize="TextChanges"
                            HeightRequest="104"
                            SemanticProperties.Hint="Describe this food or drink" />
                </VerticalStackLayout>
            </Border>

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="16">
                    <Label Text="Nutrition data" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#06A8B8, Dark=#6EC9D8}" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CaloriesEntry"
                               Placeholder="Calories"
                               Keyboard="Numeric"
                               SemanticProperties.Hint="Required calories as a number" />
                        <Entry x:Name="ProteinEntry"
                               Grid.Column="1"
                               Placeholder="Protein g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                        <Entry x:Name="CarbsEntry"
                               Placeholder="Carbs g"
                               Keyboard="Numeric" />
                        <Entry x:Name="FatEntry"
                               Grid.Column="1"
                               Placeholder="Fat g"
                               Keyboard="Numeric" />
                    </Grid>
                    <Entry x:Name="AllergyEntry"
                           Placeholder="Allergy note or dietary restriction"
                           SemanticProperties.Hint="Enter allergy or dietary information" />
                </VerticalStackLayout>
            </Border>

            <Border x:Name="ValidationPanel"
                    IsVisible="False"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F0E8F8, Dark=#402A48}"
                    Padding="18">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="14" />
                </Border.StrokeShape>
                <Label x:Name="ValidationLabel"
                       TextColor="{AppThemeBinding Light=#6B2E8E, Dark=#D9B4FF}"
                       FontAttributes="Bold"
                       FontSize="15" />
            </Border>

            <Button Text="Save record"
                    FontAttributes="Bold"
                    FontSize="18"
                    Padding="0,16"
                    BackgroundColor="#0D7DBE"
                    TextColor="#FFFFFF"
                    CornerRadius="24"
                    Clicked="OnSaveClicked"
                    SemanticProperties.Hint="Validate and save this record" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
