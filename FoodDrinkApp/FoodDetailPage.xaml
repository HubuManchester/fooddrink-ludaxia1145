<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="FoodDrinkApp.FoodDetailPage"
             Title="Nutrition Details">
    <ScrollView>
        <ScrollView.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="{AppThemeBinding Light=#E8F4F8, Dark=#0D1B24}" Offset="0.0" />
                <GradientStop Color="{AppThemeBinding Light=#F0F9FB, Dark=#0F1E2A}" Offset="1.0" />
            </LinearGradientBrush>
        </ScrollView.Background>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Border StrokeThickness="0" Padding="24">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="{AppThemeBinding Light=#0D7DBE, Dark=#1B4A6B}" Offset="0.0" />
                        <GradientStop Color="{AppThemeBinding Light=#1FA5D9, Dark=#2E7AA8}" Offset="0.72" />
                        <GradientStop Color="{AppThemeBinding Light=#06A8B8, Dark=#2B6B82}" Offset="1.0" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                    <Label x:Name="NameLabel"
                           FontSize="36"
                           FontAttributes="Bold"
                           TextColor="#FFFFFF"
                           SemanticProperties.HeadingLevel="Level1" />
                    <Label x:Name="CategoryLabel"
                           Grid.Row="1"
                           FontSize="17"
                           TextColor="#E8F4F8" />
                    <Label x:Name="CaloriesLabel"
                           Grid.Row="2"
                           FontSize="28"
                           FontAttributes="Bold"
                           TextColor="#C8E8F8" />
                </Grid>
            </Border>

            <Border StrokeThickness="2"
                    Stroke="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}"
                    BackgroundColor="{AppThemeBinding Light=#FFFBF9, Dark=#1A2227}"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="14">
                    <Label Text="Nutrition overview" FontSize="18" FontAttributes="Bold" TextColor="{AppThemeBinding Light=#0D7DBE, Dark=#7DD4E6}" />
                    <Label x:Name="MacroLabel" FontSize="17" TextColor="{AppThemeBinding Light#06A8B8, Dark=#6EC9D8}" />
                    <BoxView HeightRequest="2" Color="{AppThemeBinding Light=#B8E0F0, Dark=#3E4A5A}" />
                    <Label x:Name="DescriptionLabel" FontSize="16" TextColor="{AppThemeBinding Light#4A6A7A, Dark=#C0D8E8}" />
                    <Label x:Name="AllergyLabel" FontSize="16" FontAttributes="Bold" TextColor="{AppThemeBinding Light#0D5A8E, Dark=#8EC9E6}" />
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                <Button Text="Read summary"
                        FontSize="16"
                        Padding="0,14"
                        BackgroundColor="#0D7DBE"
                        TextColor="#FFFFFF"
                        CornerRadius="22"
                        Clicked="OnSpeakClicked"
                        SemanticProperties.Hint="Read the nutrition summary aloud" />
                <Button Grid.Column="1"
                        Text="Stop reading"
                        FontSize="16"
                        Padding="0,14"
                        BackgroundColor="{AppThemeBinding Light#FFFBF9, Dark=#1A2227}"
                        BorderColor="{AppThemeBinding Light#B8E0F0, Dark=#3E4A5A}"
                        BorderWidth="2"
                        TextColor="{AppThemeBinding Light#0D7DBE, Dark=#7DD4E6}"
                        CornerRadius="22"
                        Clicked="OnStopSpeechClicked"
                        SemanticProperties.Hint="Stop the current speech" />
            </Grid>

            <Button Text="Vibration reminder"
                    FontSize="17"
                    Padding="0,15"
                    BackgroundColor="#06A8B8"
                    TextColor="#FFFFFF"
                    CornerRadius="24"
                    Clicked="OnVibrateClicked"
                    SemanticProperties.Hint="Use mobile vibration as a meal reminder" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
